{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "paths": {
      "@tokenmeter/core": ["../../packages/core/src/index.ts"],
      "@tokenmeter/core/*": ["../../packages/core/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
