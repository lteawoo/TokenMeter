{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TokenMeter",
  "version": "0.1.7",
  "identifier": "com.lteawoo.tokenmeter",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "VITE_TOKENMETER_RUNTIME=desktop pnpm dev",
    "beforeBuildCommand": "VITE_TOKENMETER_RUNTIME=desktop pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TokenMeter",
        "width": 352,
        "height": 332,
        "resizable": false,
        "decorations": false,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
